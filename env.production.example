# Variables de Entorno para Hostinger

# Base de Datos MongoDB
MONGODB_URI=tu_mongodb_uri_aqui

# URL de tu Frontend desplegado
FRONTEND_URL=https://tu-dominio-hostinger.com

# JWT Secret
JWT_SECRET=tu_jwt_secreto_aqui

# Stripe (Producción)
STRIPE_SECRET_KEY=tu_stripe_secret_key_produccion
STRIPE_WEBHOOK_SECRET=tu_stripe_webhook_secret_produccion

# Puerto (Hostinger generalmente usa el puerto que asigna)
PORT=3000
